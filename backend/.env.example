# FinSight AI — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── Server ────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1
BASE_URL=http://localhost:5000

# ─── Database ──────────────────────────────
MONGODB_URI=mongodb://localhost:27017/finsight_ai
MONGODB_URI_TEST=mongodb://localhost:27017/finsight_ai_test

# ─── JWT ───────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES_IN=7

# ─── OpenAI / AI Provider ──────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# ─── Redis (Caching) ───────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ─── Email (Nodemailer) ────────────────────
EMAIL_FROM=noreply@finsight.ai
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password

# ─── Rate Limiting ─────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX=20

# ─── File Upload ───────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/
ALLOWED_FILE_TYPES=csv,xlsx,xls

# ─── External APIs ─────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
NEWS_API_KEY=your_newsapi_key
FINNHUB_API_KEY=your_finnhub_key
POLYGON_API_KEY=your_polygon_key

# ─── PDF Generation ────────────────────────
PDF_STORAGE_PATH=uploads/reports/

# ─── Logging ───────────────────────────────
LOG_LEVEL=debug
LOG_FILE=logs/app.log
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ─── Frontend URL (CORS) ───────────────────
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://finsight.ai

# ─── Security ──────────────────────────────
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your_session_secret

# ─── Swagger ───────────────────────────────
SWAGGER_USER=admin
SWAGGER_PASSWORD=swagger_password
