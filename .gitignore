# FinSight AI — Root .gitignore
# ================================

# ─── Environment Variables ─────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Node Modules ──────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Build Outputs ─────────────────────────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/

# ─── Logs ──────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Runtime & OS Artifacts ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ─── Uploads (user content — not committed) ────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep

# ─── Coverage & Test Output ────────────────────────────────────────────────
coverage/
**/coverage/
*.lcov
.nyc_output/

# ─── TypeScript Build Cache ────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Vite Cache ────────────────────────────────────────────────────────────
.vite/

# ─── Docker ────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml
